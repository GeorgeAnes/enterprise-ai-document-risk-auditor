# Core mode. Keep "off" for deterministic local audits with no paid API calls.
LLM_MODE=off

# Optional Gemini reviewer mode.
# To test the non-deterministic reviewer:
# 1. Copy this file to .env
# 2. Set LLM_MODE=gemini
# 3. Replace the placeholder below with your real Gemini API key
# 4. Restart the backend
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional LM Studio or other OpenAI-compatible local endpoint.
# To use LM Studio:
# 1. Start the local server in LM Studio
# 2. Set LLM_MODE=openai_compatible
# 3. Set OPENAI_MODEL to the model id shown in LM Studio
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_API_KEY=lm-studio
OPENAI_MODEL=google/gemma-4-e4b

# Optional hosted OpenAI mode. Do not commit real keys.
# LLM_MODE=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=

# Frontend API location.
VITE_API_BASE_URL=http://127.0.0.1:8010
