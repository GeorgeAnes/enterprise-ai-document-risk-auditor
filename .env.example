# Core mode. Keep "off" for deterministic local audits with no paid API calls.
LLM_MODE=off

# Optional LM Studio or other OpenAI-compatible local endpoint.
# Set LLM_MODE=openai_compatible to experiment with this path.
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_API_KEY=lm-studio
OPENAI_MODEL=local-model

# Optional hosted OpenAI mode. Do not commit real keys.
# LLM_MODE=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=

# Frontend API location.
VITE_API_BASE_URL=http://127.0.0.1:8010
